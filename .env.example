# Scholar's Terminal Configuration
# Copy this file to .env and customize for your setup

# Database path (defaults to ./data/vector_db if not set)
# CHROMA_DB_PATH=/path/to/your/vector_db

# Ollama API URL (defaults to http://localhost:11434)
# OLLAMA_URL=http://localhost:11434

# Default LLM model (defaults to llama3.2)
# DEFAULT_MODEL=llama3.2

# Research Scanner Configuration
# RESEARCH_EMAIL=your.email@example.com
# RESEARCH_KEYWORDS=artificial intelligence,machine learning,quantum computing
